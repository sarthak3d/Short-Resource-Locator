# MongoDB
MONGODB_URI=mongodb://localhost:27017/srl_db

# PostgreSQL
# Example: jdbc:postgresql://localhost:5432/srl_analytics
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# Security
# JWT Secret MUST be identical between srlDashboard and srlAnalytics
# Generate a secure random 256-bit string
JWT_SECRET=your_super_secret_jwt_key_here

# Email Notifications
# Get an API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=onboarding@resend.dev

# Frontend
# These URLs tell the frontend where the backend services are running.
# Example local configuration:
NEXT_PUBLIC_DASHBOARD_API=http://localhost:8080
NEXT_PUBLIC_SRL_BASE=localhost:8081
NEXT_PUBLIC_ANALYTICS_API=http://localhost:8082
